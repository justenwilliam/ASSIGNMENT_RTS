    [ "r1:2", "esp:GND.1", "green", [] ],

    [ "esp:13", "logic1:D0", "yellow", [] ],
    [ "esp:12", "logic1:D1", "yellow", [] ],

    [ "lcd1:GND", "esp:GND.2", "black", [] ],
    [ "lcd1:VCC", "esp:5V", "red", [] ],
    [ "lcd1:SDA", "esp:21", "blue", [] ],
